<Page x:Class="Restik.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Restik.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
            <TextBlock Text="Вход в систему" FontSize="24" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <TextBlock Text="Логин:" Margin="0,5,0,0" HorizontalAlignment="Left"/>
            <TextBox x:Name="tbUserName" Margin="0,5" Padding="5"/>

            <TextBlock Text="Пароль:" Margin="0,5,0,0" HorizontalAlignment="Left"/>
            <PasswordBox x:Name="pbPassword" Margin="0,5" Padding="5"/>

            <Button x:Name="btnLogin" Content="Войти" Click="btnLogin_Click" Margin="0,10" Padding="10,5"/>
            <Button x:Name="btnRegister" Content="Регистрация" Click="btnRegister_Click" Margin="0,5" Padding="10,5" Background="LightBlue"/>
            <TextBlock x:Name="tbMessage" Foreground="Red" Margin="0,10" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
