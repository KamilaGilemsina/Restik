<Page x:Class="Restik.Pages.DishesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Restik.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DishesPage" Loaded="Page_Loaded">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="tbSearch" Width="200" Margin="5" TextChanged="tbSearch_TextChanged" />
            <ComboBox x:Name="cmbCategory" Width="150" Margin="5" SelectionChanged="cmbCategory_SelectionChanged"/>
            <ComboBox x:Name="cmbSort" Width="100" Margin="5" SelectionChanged="cmbSort_SelectionChanged">
                <ComboBoxItem Content="По названию"/>
                <ComboBoxItem Content="По цене (возр.)"/>
                <ComboBoxItem Content="По цене (убыв.)"/>
            </ComboBox>
        </StackPanel>

        <Button x:Name="btnAdd" Content="Добавить блюдо" Click="btnAdd_Click" HorizontalAlignment="Right" Margin="5,0,0,10" Width="120"/>

        <ListView x:Name="lvDishes" Grid.Row="2" Margin="5" SelectionMode="Single">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Фото" Width="80">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Image Source="{Binding CategoryImage}" Width="60" Height="60" Stretch="Uniform"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Название" DisplayMemberBinding="{Binding Name}" Width="150"/>
                    <GridViewColumn Header="Описание" DisplayMemberBinding="{Binding Description}" Width="200"/>
                    <GridViewColumn Header="Цена" DisplayMemberBinding="{Binding Price, StringFormat={}{0:C}}" Width="80"/>
                    <GridViewColumn Header="Категория" DisplayMemberBinding="{Binding CategoryName}" Width="100"/>
                    <GridViewColumn Header="Доступно" DisplayMemberBinding="{Binding IsAvailable, StringFormat={}{0:Да;Нет}}" Width="80"/>
                    <GridViewColumn Header="Действия" Width="150">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Изменить" Click="EditDish_Click" Tag="{Binding ID}" Margin="2" Padding="5,2"/>
                                    <Button x:Name="btnDelete" Content="Удалить" Click="DeleteDish_Click" Tag="{Binding ID}" Margin="2" Padding="5,2"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Page>
