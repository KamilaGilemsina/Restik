<Window x:Class="Restik.Windows.AddEditOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Restik.Windows"
        mc:Ignorable="d"
        Title="AddEditOrderWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Столик:" Grid.Row="0" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="tbTable" Grid.Row="0" Grid.Column="1" Margin="5"/>

        <TextBlock Text="Кол-во гостей:" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="tbCustomers" Grid.Row="1" Grid.Column="1" Margin="5"/>

        <TextBlock Text="Статус:" Grid.Row="2" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbStatus" Grid.Row="2" Grid.Column="1" Margin="5" DisplayMemberPath="Name" SelectedValuePath="ID"/>

        <TextBlock Text="Официант:" Grid.Row="3" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbWaiter" Grid.Row="3" Grid.Column="1" Margin="5" DisplayMemberPath="FullName" SelectedValuePath="ID"/>

        <TextBlock Text="Примечание:" Grid.Row="4" Grid.Column="0" Margin="5" VerticalAlignment="Top"/>
        <TextBox x:Name="tbNotes" Grid.Row="4" Grid.Column="1" Margin="5" TextWrapping="Wrap" AcceptsReturn="True" Height="60"/>

        <GroupBox Header="Блюда в заказе" Grid.Row="5" Grid.ColumnSpan="2" Margin="5">
            <DataGrid x:Name="dgOrderItems" AutoGenerateColumns="False" CanUserAddRows="True" CanUserDeleteRows="True">
                <DataGrid.Columns>
                    <DataGridComboBoxColumn Header="Блюдо" SelectedValueBinding="{Binding DishID}" DisplayMemberPath="Name" SelectedValuePath="ID"/>
                    <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}"/>
                    <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice, StringFormat={}{0:C}}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Сумма" Binding="{Binding Subtotal, StringFormat={}{0:C}}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Примечание" Binding="{Binding Notes}"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <Button x:Name="btnSave" Content="Сохранить" Click="btnSave_Click" Grid.Row="6" Grid.ColumnSpan="2" Width="100" HorizontalAlignment="Center" Margin="5"/>
        <TextBlock x:Name="tbMessage" Grid.Row="6" Grid.ColumnSpan="2" Foreground="Red" Margin="5" HorizontalAlignment="Center" VerticalAlignment="Top" Height="Auto"/>
    </Grid>
</Window>
